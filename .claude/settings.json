{
  "enabledPlugins": {
    "pm-toolkit@pm-skills": true,
    "pm-product-strategy@pm-skills": true,
    "pm-product-discovery@pm-skills": true,
    "pm-market-research@pm-skills": true,
    "pm-data-analytics@pm-skills": true,
    "pm-marketing-growth@pm-skills": true,
    "pm-execution@pm-skills": true,
    "pm-go-to-market@pm-skills": true
  },
  "extraKnownMarketplaces": {
    "pm-skills": {
      "source": {
        "source": "github",
        "repo": "phuryn/pm-skills"
      }
    }
  },
  "permissions": {
    "deny": [
      "Bash(rm -rf /:*)",
      "Bash(rm -rf ~:*)",
      "Bash(rm -rf $HOME:*)",
      "Bash(rm -rf ..:*)",
      "Bash(:(){ :|:& };:)",
      "Bash(git config --global*)",
      "Bash(git push --force*main*)",
      "Bash(git push --force-with-lease*main*)",
      "Bash(git reset --hard origin/main)",
      "Bash(git push *no-verify*)",
      "Bash(git commit *no-verify*)",
      "Bash(curl *| sh*)",
      "Bash(curl *| bash*)",
      "Bash(wget *| sh*)",
      "Bash(wget *| bash*)",
      "Bash(npm publish *ignore-scripts*)",
      "Bash(sudo:*)",
      "Bash(chmod 777:*)",
      "Bash(* > /dev/*)",
      "Write(/dev/*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(~/.ssh/*)",
      "Read(~/.aws/credentials)"
    ]
  }
}
